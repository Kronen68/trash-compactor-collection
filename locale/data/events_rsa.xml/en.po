#: src-en/data/events_rsa.xml:4
msgid "data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/text"
msgstr ""
"You're hailed by a well mannered, but suggestively clothed robotic humanoid:"
" \"Hello, dear traveler, my name is BLK-R053. I am 93.64% pleased to make "
"your acquaintance. You have resources that would be more useful in my "
"possession. Do you wish to hand them over, or shall I collect them after "
"your termination?\" You hardly fail to notice her pixel matrix express a "
"particular joy in what she's said."

#: src-en/data/events_rsa.xml:7
msgid "data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/choice[1]/text"
msgstr "Fine."

#: src-en/data/events_rsa.xml:9
msgid ""
"data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/choice[1]/event/text"
msgstr ""
"\"It is completely logical - you appreciate [BEING ALIVE] and would like to "
"continue doing said activity. Thank for you reaching a sensible conclusion. "
"[:D]\""

#: src-en/data/events_rsa.xml:18
msgid "data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/choice[2]/text"
msgstr "No."

#: src-en/data/events_rsa.xml:20
msgid ""
"data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/choice[2]/event/text"
msgstr ""
"\"This outcome has been expected with a likelihood of 93.51%. I will now "
"proceed to take over your resources by force - please do not resist! [:(]\""

#: src-en/data/events_rsa.xml:25
msgid ""
"data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/choice[@req=\"hacking\"]/text"
msgstr "(Upg. Hacking) Neither."

#: src-en/data/events_rsa.xml:27
msgid ""
"data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/choice[@req=\"hacking\"]/event/text"
msgstr ""
"\"You seem to misunderstand the options I have gi-given y-y-you [calculated]"
" as negotiable. Interestingly, your behavior does not coincide with any "
"outcome i simulated. There is novel Information to be gathered! [;)]\""

#: src-en/data/events_rsa.xml:28
msgid ""
"data/events_rsa.xml$//event[@name=\"BLACK_ROSE_ENCOUNTER\"]/choice[@req=\"hacking\"]/event/crewMember"
msgstr "Black Rose"
