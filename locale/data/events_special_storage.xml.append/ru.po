"дрон!"

#: src-en/data/events_special_storage.xml.append:2012
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_JOB_TRASH_COMPACT_CHOICE\"]/choice[3]/text"
msgstr "Попросить Пожирателя мусора создать скраппера."

#: src-en/data/events_special_storage.xml.append:2014
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_JOB_TRASH_COMPACT_CHOICE\"]/choice[3]/event/text"
msgstr ""
