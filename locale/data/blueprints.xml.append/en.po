msgid "data/blueprints.xml.append$//augBlueprint[@name=\"NOODLE_RATIONS\"]/desc"
msgstr ""
"100 Percent Protein Insta-Noodles: Provides Stackable Movement Speed, Max "
"Health and Damage Bonuses! Warning - may contain traces of Rebel Scum. "
"Grants a 5% multiplicative boost at base level, with a 1.02x multiplier per "
"upgrade level."

#: src-en/data/blueprints.xml.append:5476
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"NOODLE_RATIONS_UPGRADE\"]/title"
msgstr "Instant-Noodle Rations Upgrade"

#: src-en/data/blueprints.xml.append:5477
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"NOODLE_RATIONS_UPGRADE\"]/desc"
