msgid "data/blueprints.xml.append$//augBlueprint[@name=\"COMPACTOR\"]/desc"
msgstr ""
"A heavy machine that makes compact bricks of scrap which is then used by a "
"specialized 3D printer to craft one of the pre-selected items."

#: src-en/data/blueprints.xml.append:5427
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"SCRAP_COMPACTOR\"]/title"
msgstr "Proto-Compactor"

#: src-en/data/blueprints.xml.append:5428
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"SCRAP_COMPACTOR\"]/desc"
msgstr ""
"A prototype design cobbled together out of old 3D printer parts and a "
"civillian-spec dumpster compactor. You could probably make a few things with"
" it... although you're not sure that you can program it correctly."

#: src-en/data/blueprints.xml.append:5435
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"ADVANCED_SCRAP\"]/title"
msgstr "Advanced Scrap Processor"

#: src-en/data/blueprints.xml.append:5436
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"ADVANCED_SCRAP\"]/desc"
msgstr ""
"An advanced scrap processor created by the Trash Eater himself. It may be "
"used to upgrade some scrappers into their elite variants."

