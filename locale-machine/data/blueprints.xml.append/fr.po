#: src-en/data/blueprints.xml.append:8888
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_SLUGTON_2\"]/desc"
msgstr ""
"Ce vaisseau appartenait à la Kleptocratie Limace - sans surprise, c'est "
"maintenant un vaisseau de bandits qui s'attaque aux civils."

#: src-en/data/blueprints.xml.append:8960
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_SLUGTON_3\"]/class"
msgstr "Vaisseau Amiral à Louer"

#: src-en/data/blueprints.xml.append:8961
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_SLUGTON_3\"]/name"
