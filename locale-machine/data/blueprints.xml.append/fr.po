"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_SMEW_BATTLECRUISER\"]/class"
msgstr "Croiseur de Bataille Smew"

#: src-en/data/blueprints.xml.append:8360
msgid ""
"data/blueprints.xml.append$//shipBlueprint[@name=\"PLAYER_SHIP_SMEW_BATTLECRUISER\"]/name"
