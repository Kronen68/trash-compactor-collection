#: src-en/data/events_special_storage.xml.append:1772
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_JOB_TRASH_COMPACT_CHOICE\"]/choice[1]/event/text"
msgstr ""
"Le Mange-Déchets hoche la tête et commence son travail - et du tango "
