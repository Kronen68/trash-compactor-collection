msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"ENCOUNTER_TC3\"]/choice[4]/text"
msgstr "Nous n'avons rien à faire ici…"

#: src-en/data/events_special_multiverse.xml.append:1649
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"ENCOUNTER_TC4\"]/text"
msgstr ""
"Hé, il y a un deuxième vaisseau ici. Et il n'est pas hostile. En fait, ce "
"n'est même pas un Ferrailleur. C'est un charognard d'une sorte, à en juger "
"par sa coque terriblement endommagée et sale. Clairement peint comme un "
"vaisseau d'élimination des déchets - mais il est beaucoup trop bien armé "
"pour en être un."

#: src-en/data/events_special_multiverse.xml.append:1652
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"ENCOUNTER_TC4\"]/beaconType/unvisitedTooltip"
msgstr "V3NEZ L3 CHERCHeR"

#: src-en/data/events_special_multiverse.xml.append:1653
