msgstr "Présentez un Scrapper."

#: src-en/data/events_special_multiverse.xml.append:2112
msgid ""
"data/events_special_multiverse.xml.append$//mod:findName[@name=\"THE_JUDGES_ZOLTAN\"]/mod-"
"append:choice/event/text"
msgstr ""
"\"Les... thésauriseurs Lanius. Leur avidité pour... la ferraille les a "
"changés. En inviter un sur votre vaisseau est... surprenant. Oui, je suis..."
" impressionné. Bien joué, voyageur. Attendez-vous à... des récompenses avant"
" votre prochain voyage.\""

